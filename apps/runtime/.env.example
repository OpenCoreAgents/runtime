# Copy to `.env` in this directory (`apps/runtime/`, next to `docker-compose-with-redis.yml`).
# `.env` is gitignored. Load order: this file is merged into `api` and `worker` before `docker compose up`
# so you do not need to restart containers just to add keys.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional — seed a `planner` agent in Redis on startup if missing (set 0/false/off to disable).
# RUNTIME_PLANNER_DEFAULT_AGENT=1

# Optional — orchestrator LLM for that default `planner` agent (auto / omit = infer provider + gpt-4o or claude-opus-4-6).
# RUNTIME_PLANNER_AGENT_PROVIDER=auto
# RUNTIME_PLANNER_AGENT_MODEL=auto
# RUNTIME_PLANNER_AGENT_TEMPERATURE=0.2

# Optional — default LLM for dynamic-planner `spawn_agent` when the tool omits `llm` (unknown user model).
# If unset or `auto`, provider is inferred from configured keys + stack `llm.defaultProvider`; model defaults to gpt-4o-mini / claude-sonnet-4-6.
# RUNTIME_PLANNER_SUB_AGENT_PROVIDER=auto
# RUNTIME_PLANNER_SUB_AGENT_MODEL=auto
# RUNTIME_PLANNER_SUB_AGENT_TEMPERATURE=0.2

# Optional — overrides the compose default (see docker-compose-with-redis.yml)
# REST_API_KEY=

# Optional — Redis Pub/Sub run notifications + GET /v1/runs/:runId/stream (SSE). Stack: runEvents.redis: true
# RUNTIME_RUN_EVENTS_REDIS=1

# Optional — disable default chat agent + POST /v1/chat (stack: chat.defaultAgent.enabled: false)
# RUNTIME_CHAT_DEFAULT_AGENT=0

# Optional — LLM row for lazy-seeded default `chat` agent (same auto rules as planner orchestrator)
# RUNTIME_CHAT_AGENT_PROVIDER=auto
# RUNTIME_CHAT_AGENT_MODEL=auto
# RUNTIME_CHAT_AGENT_TEMPERATURE=0.2
