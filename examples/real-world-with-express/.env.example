# Optional — chat uses a real model when a key is set (see EXPRESS_LLM_PROVIDER).
OPENAI_API_KEY=
# Optional model override (default gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
# Optional model override (default claude-sonnet-4-6 — older snapshots retire; see Anthropic model docs).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: force vendor when both keys exist — openai | anthropic
# EXPRESS_LLM_PROVIDER=openai

# HTTP port (default 3000).
PORT=3000

# Optional — if set, all /v1/* routes require: Authorization: Bearer <API_KEY>
# (host-layer gate; /health stays public for load balancer probes).
API_KEY=

# Max wait for in-flight HTTP handlers during SIGTERM/SIGINT before force exit (default 10000 ms).
SHUTDOWN_TIMEOUT_MS=10000
